/* ========== HANDCRAFTED DESIGN SYSTEM — WorkBoard ========== */
:root {
  --bg-dark: #030308;
  --bg-card: #0a0a14;
  --border: rgba(255, 255, 255, 0.08);
  --text-primary: #ffffff;
  --text-secondary: #94a3b8;
  --text-muted: #55556a;
  --accent: #7c3aed;
  --accent-light: #a78bfa;
  --accent-glow: rgba(124, 58, 237, 0.2);
  --green: #10b981;
  --yellow: #f59e0b;
  --red: #ef4444;
  --blue: #3b82f6;
  --pink: #ec4899;
  --radius-xl: 24px;
  --font: 'Inter', -apple-system, sans-serif;
}

html, body {
  margin: 0 !important;
  padding: 0 !important;
  width: 100vw;
  height: 100vh;
  overflow: hidden !important;
  background: var(--bg-dark);
}

body {
  font-family: var(--font);
  color: var(--text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

*, *::before, *::after { box-sizing: border-box; }

.auth-wrapper {
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 50% 50%, #0f172a 0%, #030308 100%);
  overflow: hidden;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
}

.auth-main-card {
  width: 100%;
  max-width: 1100px;
  display: flex;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 50px 100px rgba(0, 0, 0, 0.8);
  position: relative;
  z-index: 100;
}
